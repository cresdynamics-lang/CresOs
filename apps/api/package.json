{
  "name": "cresos-api",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:director-ai-e2e": "DIRECTOR_AI_E2E_DELAY_MS=0 vitest run tests/director-ai-developer-report.e2e.test.ts",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "latest",
    "cors": "latest",
    "docxtemplater": "^3.68.3",
    "dotenv": "latest",
    "express": "latest",
    "file-saver": "^2.0.5",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "latest",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "prisma": "^5.20.0",
    "resend": "latest",
    "ws": "^8.18.3",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/file-saver": "^2.0.7",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
