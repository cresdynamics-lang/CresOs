# Database (Prisma)
DATABASE_URL=

# Auth
JWT_SECRET=

# Server
PORT=4000

# Resend (outbound email; set MAIL_MAILER=resend to disable SMTP sending)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Cres Dynamics <info@cresdynamics.com>
RESEND_REPLY_TO=info@cresdynamics.com
RESEND_FROM_EMAIL_FINANCE=Cres Dynamics Finance <finance-noreply@cresdynamics.com>
RESEND_REPLY_TO_FINANCE=info@cresdynamics.com
RESEND_FROM_EMAIL_SALES=Cres Dynamics Sales <sales-noreply@cresdynamics.com>
RESEND_REPLY_TO_SALES=info@cresdynamics.com
RESEND_FROM_EMAIL_DIRECTOR=Cres Dynamics <director-noreply@cresdynamics.com>
RESEND_REPLY_TO_DIRECTOR=info@cresdynamics.com
# Shown in compose email footers (no-reply + contact instructions)
COMPOSE_CONTACT_PHONE=0708805496
COMPOSE_CONTACT_PHONE_E164=254708805496
COMPOSE_REPLY_EMAIL=info@cresdynamics.com
MAIL_MAILER=resend

# Groq AI — primary + fallbacks for different sections/rate limits
GROQ_API_KEY=
GROQ_API_KEY_SECONDARY=
GROQ_API_KEY_TERTIARY=
GROQ_REMINDER_MODEL=llama-3.3-70b-versatile
GROQ_EMAIL_MODEL=llama-3.3-70b-versatile
GROQ_DIRECTOR_MODEL=llama-3.3-70b-versatile
EMAIL_AUTOMATION_POLL_INTERVAL=10
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
